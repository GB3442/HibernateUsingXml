<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="org.example.Entity.Mobile" table="mobile">

        <id name="id" column="id">
            <generator class="increment"/>
        </id>


        <property name="brand" column="brand" length="100" not-null="true"/>

        <set name="modelList" cascade="all" fetch="select" inverse="true">
            <key column="mobile_id"/>
            <one-to-many class="org.example.Entity.Model"/>
        </set>
    </class>
</hibernate-mapping>
